{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TenderIQAuditLogEvent",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "event_type",
    "session_id",
    "tender_id",
    "reveal_status",
    "model_version",
    "config_version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "user_id_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "tender_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "scenario_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "reveal_status": {
      "type": "string",
      "enum": [
        "hidden",
        "revealed",
        "not_applicable"
      ]
    },
    "input_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "output_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "model_version": {
      "type": "string"
    },
    "config_version": {
      "type": "string"
    },
    "details": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
